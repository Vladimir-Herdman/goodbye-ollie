   <text:p text:style-name="P81"><text:s text:c="18"/>l <text:s text:c="22"/>‘t <text:s text:c="33"/>.</text:p>
   <text:p text:style-name="P81"><text:s text:c="20"/>l <text:s text:c="21"/>s</text:p>
   <text:p text:style-name="P81"><text:s text:c="45"/>to</text:p>
   <text:p text:style-name="P81"><text:s text:c="50"/>p</text:p>
   <text:p text:style-name="P81"/>
   <text:p text:style-name="P81"/>
   <text:p text:style-name="P81"><text:s text:c="65"/>We t an</text:p>
   <text:p text:style-name="P81"><text:s text:c="76"/>d</text:p>
   <text:p text:style-name="P81"><text:s text:c="73"/>dr I p</text:p>
   <text:p text:style-name="P81"><text:s text:c="81"/>pin g</text:p>
   <text:p text:style-name="P81"><text:s text:c="65"/>do w</text:p>
   <text:p text:style-name="P81"><text:s text:c="73"/>n <text:s text:c="2"/>t h</text:p>
   <text:p text:style-name="P81"><text:s text:c="83"/>e</text:p>
   <text:p text:style-name="P81"><text:s text:c="81"/>p</text:p>
