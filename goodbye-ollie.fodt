     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1023_1230340041" office:name="Between My Ears I Cannot Sing" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Between My Ears I Cannot Sing<text:tab/>40</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc2551_4237564503" office:name="Swampman" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Swampman<text:tab/>42</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1315_3007704144" office:name="As I Lay Here Beside You" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">As I Lay Here Beside You<text:tab/>44</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1125_1230340041" office:name="Instagramification – No Time And Nothing To Do" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Instagramification – No Time And Nothing To Do<text:tab/>45</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc6575_3499536570" office:name="Unlike Anyone Else" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Unlike Anyone Else<text:tab/>46</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc2549_4237564503" office:name="Instagramification – Eat For The Future (2024)" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Instagramification – Eat For The Future (2024)<text:tab/>48</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc2547_4237564503" office:name="I Confess I Confess" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">I Confess I Confess<text:tab/>49</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc2545_4237564503" office:name="That I’m A Good Liar" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">That I’m A Good Liar<text:tab/>50</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc2543_4237564503" office:name="That I’m Happy" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">That I’m Happy<text:tab/>51</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc6573_3499536570" office:name="Oliver From Memory" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Oliver From Memory<text:tab/>52</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc6571_3499536570" office:name="Modern" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Modern<text:tab/>53</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1969_4086586558" office:name="Nothing Hurts" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Nothing Hurts<text:tab/>54</text:a></text:p>
     <text:p text:style-name="P29"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc776_3676532460" office:name="Goodbye Ollie," text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Goodbye Ollie,<text:tab/>57</text:a></text:p>
     <text:p text:style-name="P28"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1996_818021894" office:name="Acknowledgments" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">Acknowledgments<text:tab/>58</text:a></text:p>
     <text:p text:style-name="P28"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1994_818021894" office:name="About the Author" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">About the Author<text:tab/>59</text:a></text:p>
     <text:p text:style-name="P28"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1992_818021894" office:name="About the Muse" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">About the Muse<text:tab/>60</text:a></text:p>
     <text:p text:style-name="P28"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc8138_1175081228" office:name="TEST" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">TEST<text:tab/>61</text:a></text:p>
    </text:index-body>
   </text:table-of-content>
   <text:p text:style-name="P30"/>
   <text:p text:style-name="P135"/>
   <text:h text:style-name="P139" text:outline-level="1"><text:bookmark-start text:name="__RefHeading___Toc1293_3676532460"/>Preface<text:bookmark-end text:name="__RefHeading___Toc1293_3676532460"/></text:h>
   <text:p text:style-name="P34"/>
   <text:p text:style-name="P36"><text:span text:style-name="T6">The sum total of this book amounts to nothing but a joke. I refuse to stop telling this joke all on the grounds that I find it funny. I’ve lately been stopping myself, because I think it’s in bad taste now that Ollie’s escaped me. I’ve reached my bounds. A book I reread recently captures what I hope to present through this collection</text:span>:</text:p>
   <text:p text:style-name="P37"/>
   <text:p text:style-name="Quote">All of the true things I am about to tell you are shameless lies.</text:p>
   <text:p text:style-name="Quote"><text:span text:style-name="T8">—</text:span><text:span text:style-name="T9">Kurt Vonnegut, Jr., </text:span><text:span text:style-name="T6">Cat’s Cradle</text:span></text:p>
   <text:p text:style-name="P38"/>
   <text:p text:style-name="P39">Nothing in these pages are true. Everything I’ve written comes from my heart and what I believe to be somewhat funny, or a little interesting. That probably means there’s something true in here, but that’s not up to me to decide.</text:p>
   <text:p text:style-name="P40"/>
   <text:p text:style-name="P41">Otherwise, all writing was formed with a single thought in mind: “How do I make Ollie a little uncomfortable here, but still willing to laugh about it?” If I hit the mark, you’ll know. <text:span text:style-name="T15">If not, forgive me— Nothing was meant too serious to cause harm. </text:span><text:span text:style-name="T16">And yes, I use the em-dash: NO AI was used throughout </text:span><text:span text:style-name="T17">this collection</text:span><text:span text:style-name="T16">.</text:span></text:p>
   <text:p text:style-name="P42"/>
   <text:p text:style-name="P43"><text:span text:style-name="T6">As a final </text:span><text:span text:style-name="T18">note on why I did this</text:span><text:span text:style-name="T6">, </text:span><text:span text:style-name="T18">t</text:span><text:span text:style-name="T19">here’s </text:span><text:span text:style-name="T20">nothing</text:span><text:span text:style-name="T19"> wrong with wanting to be an individual. </text:span><text:span text:style-name="T6">The only thing wrong is to </text:span><text:span text:style-name="T18">not </text:span><text:span text:style-name="T6">try.</text:span></text:p>
   <text:p text:style-name="P44"/>
   <text:p text:style-name="P43"><text:span text:style-name="T6">So that’s what I hope to get across here: I’m trying. I tried. </text:span><text:span text:style-name="T18">If I failed, better than those that never pursued a thought to its end.</text:span></text:p>
   <text:p text:style-name="P44"/>
   <text:p text:style-name="P45">Thank you.</text:p>
   <text:p text:style-name="P136"/>
   <text:p text:style-name="P32"/>
   <text:p text:style-name="Text_20_body"/>
   <text:p text:style-name="Text_20_body"/>
   <text:p text:style-name="Text_20_body"/>
   <text:p text:style-name="P46">I aint ever felt better and</text:p>
   <text:p text:style-name="P46">I aint ever been dumbe<text:span text:style-name="T1">r.</text:span></text:p>
   <text:p text:style-name="P47"><text:span text:style-name="T7">—</text:span><text:span text:style-name="T10">Jesse Welles</text:span></text:p>
   <text:p text:style-name="P50"/>
   <text:p text:style-name="P21">To give anything less than your best</text:p>
   <text:p text:style-name="P21">is to sacrifice the gift.</text:p>
   <text:p text:style-name="P51">—<text:span text:style-name="T21">Steve Prefontaine</text:span></text:p>
   <text:p text:style-name="P47"/>
   <text:p text:style-name="P48"><text:span text:style-name="Emphasis">I can’t even guess myself what it must be</text:span></text:p>
   <text:p text:style-name="P48"><text:span text:style-name="Emphasis">to live the life of a human being.</text:span></text:p>
   <text:p text:style-name="P47"><text:span text:style-name="Emphasis"><text:span text:style-name="T22">—</text:span></text:span><text:span text:style-name="Emphasis"><text:span text:style-name="T23">Osamu Dazai, </text:span></text:span><text:span text:style-name="Emphasis"><text:span text:style-name="T25">No Longer Human</text:span></text:span></text:p>
   <text:p text:style-name="P47"><text:span text:style-name="Emphasis"><text:span text:style-name="T25"/></text:span></text:p>
   <text:p text:style-name="P22">See the cat?</text:p>
   <text:p text:style-name="P52"><text:span text:style-name="Emphasis"><text:span text:style-name="T26">See the cradle?</text:span></text:span></text:p>
   <text:p text:style-name="P52"><text:span text:style-name="Emphasis"><text:span text:style-name="T22">—Kurt Vonnegut, Jr., </text:span></text:span><text:span text:style-name="Emphasis"><text:span text:style-name="T26">Cat’s Cradle</text:span></text:span></text:p>
   <text:p text:style-name="P47"><text:span text:style-name="Emphasis"><text:span text:style-name="T23"/></text:span></text:p>
   <text:p text:style-name="P49"><text:span text:style-name="Emphasis"><text:span text:style-name="T27">I don’t want to be normal,</text:span></text:span></text:p>
   <text:p text:style-name="P49"><text:span text:style-name="Emphasis"><text:span text:style-name="T27">I want to be me</text:span></text:span><text:span text:style-name="Emphasis">.</text:span></text:p>
   <text:p text:style-name="P49"><text:span text:style-name="Emphasis"><text:span text:style-name="T23">—</text:span></text:span><text:span text:style-name="Emphasis"><text:span text:style-name="T24">My Brain</text:span></text:span></text:p>
   <text:p text:style-name="P54" loext:marker-style-name="T14"><text:span text:style-name="T14"/></text:p>
   <text:p text:style-name="Text_20_body"/>
   <text:h text:style-name="P142" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc155_3645116443"/><office:annotation office:name="__Annotation__441_2779579312" loext:resolved="false">
     <dc:creator>Vladimir Herdman</dc:creator>
     <dc:date>2026-05-09T23:32:14.079003000</dc:date>
     <meta:creator-initials>VTH</meta:creator-initials>
     <text:p text:style-name="Comment">I’m thinking overly positive from here, to goofy/weird, to whatever I want towards the end of the book here.</text:p>
     <text:p text:style-name="Comment"/>
    </office:annotation>Hello Ollie<office:annotation-end office:name="__Annotation__441_2779579312"/>,<text:bookmark-end text:name="__RefHeading___Toc155_3645116443"/></text:h>
   <text:p text:style-name="Poetry_20_Text"/>
   <text:p text:style-name="P55">Hello Ollie,</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">From the first moment I met you I—</text:p>
   <text:p text:style-name="P55">When we met that fated August, I really wanted to just—</text:p>
   <text:p text:style-name="P55">Ollie, the effect you’ve had on me, truly...</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">I just can’t start this letter to you. I feel I can’t speak my mind. I don’t have the words to express myself, and I keep <text:span text:style-name="T16">trying to rewrite </text:span><text:span text:style-name="T28">everything</text:span>. So, that’s what this book is for.</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">I plan on expressing some emotions— or thoughts— at least somewhere within this piece, ideas I couldn’t fully write out, ideas I had to keep rewriting ‘till I finally gave up.</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">This book, and every poem, is an attempt <text:span text:style-name="T29">a</text:span>t <text:span text:style-name="T29">some</text:span> <text:span text:style-name="T29">nebulous feeling within me</text:span>. Whether you call it poetry or not, that’s why the cover says this is a collection of “Maybe-Poems.”</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">I hope you enjoy it! I hope it’s not too weird! I hope…</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">I hope you thought it was funny.</text:p>
   <text:p text:style-name="P55"/>
   <text:p text:style-name="P55">Sincerely,</text:p>
   <text:p text:style-name="P55">Dare I say lovingly,</text:p>
   <text:p text:style-name="P55">I dare,</text:p>
   <text:p text:style-name="P55">I do dare,</text:p>
   <text:p text:style-name="P56">Love,</text:p>
   <text:p text:style-name="P55">Vova</text:p>
   <text:h text:style-name="P26" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc6587_3499536570"/>I Want You To Touch Me<text:bookmark-end text:name="__RefHeading___Toc6587_3499536570"/></text:h>
   <text:p text:style-name="P62"/>
   <text:p text:style-name="Poetry_20_Text">I promise</text:p>
   <text:p text:style-name="Poetry_20_Text">I&apos;m quoting that phrase</text:p>
   <text:p text:style-name="Poetry_20_Text"><text:span text:style-name="T30">from</text:span> the end of a poem;</text:p>
   <text:p text:style-name="Poetry_20_Text"><text:span text:style-name="T31">An</text:span><text:span text:style-name="T30"> ending </text:span>I <text:span text:style-name="T30">liked,</text:span></text:p>
   <text:p text:style-name="P56"><text:span text:style-name="T31">that</text:span> I remember<text:span text:style-name="T31">ed</text:span> wrong.</text:p>
   <text:p text:style-name="Poetry_20_Text"/>
   <text:p text:style-name="Poetry_20_Text">Enough of <text:span text:style-name="T31">the</text:span> eye tag,</text:p>
   <text:p text:style-name="Poetry_20_Text">enough of the games,</text:p>
   <text:p text:style-name="Poetry_20_Text">enough of the nights spent</text:p>
   <text:p text:style-name="Poetry_20_Text">trying to figure out</text:p>
   <text:p text:style-name="Poetry_20_Text">our names.</text:p>
   <text:p text:style-name="Poetry_20_Text">Just</text:p>
   <text:p text:style-name="Poetry_20_Text">come out and</text:p>
   <text:p text:style-name="Poetry_20_Text">hollah at <text:span text:style-name="T30">yah</text:span> boy.</text:p>
   <text:p text:style-name="Poetry_20_Text">Anymore time spent</text:p>
   <text:p text:style-name="Poetry_20_Text">away from You,</text:p>
   <text:p text:style-name="Poetry_20_Text">when we&apos;re hanging out,</text:p>
   <text:p text:style-name="Poetry_20_Text">simply splits me inside.</text:p>
   <text:p text:style-name="Poetry_20_Text">I can&apos;t take it.</text:p>
   <text:p text:style-name="Poetry_20_Text">I want</text:p>
   <text:p text:style-name="Poetry_20_Text">I</text:p>
   <text:p text:style-name="Poetry_20_Text">I <text:s text:c="2"/>want</text:p>
   <text:p text:style-name="Poetry_20_Text"><text:s text:c="11"/>you <text:s text:c="2"/>to</text:p>
   <text:p text:style-name="Poetry_20_Text"><text:s text:c="22"/>touch</text:p>
   <text:p text:style-name="Poetry_20_Text"><text:s text:c="30"/>me.</text:p>
   <text:p text:style-name="Poetry_20_Text">Put your hand out</text:p>
   <text:p text:style-name="Poetry_20_Text">with mine,</text:p>
   <text:p text:style-name="Poetry_20_Text">and interlink our fingers—</text:p>
   <text:p text:style-name="Poetry_20_Text">feel my skin on yours,</text:p>
   <text:p text:style-name="Poetry_20_Text"><text:soft-page-break/>realize the warmth I give</text:p>
   <text:p text:style-name="Poetry_20_Text">when we&apos;re</text:p>
   <text:p text:style-name="Poetry_20_Text">actually</text:p>
   <text:p text:style-name="Poetry_20_Text">here.</text:p>
   <text:h text:style-name="P57" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc8144_1175081228"/>My Happiest Moment. Ever.<text:bookmark-end text:name="__RefHeading___Toc8144_1175081228"/></text:h>
   <text:p text:style-name="Poetry_20_Text"/>
   <text:p text:style-name="Poetry_20_Text"><draw:frame draw:style-name="fr2" draw:name="Image3" text:anchor-type="char" svg:width="4.2791in" svg:height="0.9091in" draw:z-index="2"><draw:image xlink:href="images/its-a-promise.jpg" xlink:type="simple" xlink:show="embed" xlink:actuate="onLoad" draw:mime-type="image/jpeg"/>
    </draw:frame></text:p>
   <text:p text:style-name="P60"/>
   <text:p text:style-name="P56">Have you ever felt it in your bones,</text:p>
   <text:p text:style-name="P56">down even to the pip of your very being</text:p>
   <text:p text:style-name="P56"><text:span text:style-name="T32">t</text:span>hat</text:p>
   <text:p text:style-name="P56">the pulp which makes you up,</text:p>
   <text:p text:style-name="P56">this human mass of <text:span text:style-name="T32">mystery</text:span> flesh,</text:p>
   <text:p text:style-name="P56"><text:s text:c="2"/>and blood,</text:p>
   <text:p text:style-name="P56"><text:s text:c="5"/>and gummy bits,</text:p>
   <text:p text:style-name="P56">could amount to something greater</text:p>
   <text:p text:style-name="P64">if only in the presence</text:p>
   <text:p text:style-name="P64">of another?</text:p>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56">Have you ever made a promise</text:p>
   <text:p text:style-name="P56">and delayed it down the road</text:p>
   <text:p text:style-name="P56">just so you knew</text:p>
   <text:p text:style-name="P56">something good</text:p>
   <text:p text:style-name="P56">was coming?</text:p>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56">Nothing in this life</text:p>
   <text:p text:style-name="P56">would make me happier</text:p>
   <text:p text:style-name="P56">than if You</text:p>
   <text:p text:style-name="P56">were someone who</text:p>
   <text:p text:style-name="P56">kept their word<text:note text:id="ftn1" text:note-class="footnote"><text:note-citation>1</text:note-citation><text:note-body>
      <text:p text:style-name="P59">I’ll be waiting ;)</text:p></text:note-body></text:note>.</text:p>
   <text:h text:style-name="P26" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc8140_1175081228"/>Your Hips, Your Lips, Your Teeth<text:bookmark-end text:name="__RefHeading___Toc8140_1175081228"/></text:h>
   <text:p text:style-name="P65"/>
   <text:p text:style-name="P65"/>
   <text:h text:style-name="P26" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc2555_4237564503"/><office:annotation office:name="__Annotation__8953_1175081228" loext:resolved="false">
     <dc:creator>Vladimir Herdman</dc:creator>
     <dc:date>2026-07-19T13:10:57.843022000</dc:date>
     <meta:creator-initials>VTH</meta:creator-initials>
     <text:p text:style-name="Comment">TODO: complete.</text:p>
    </office:annotation>If Ollie Was<office:annotation-end office:name="__Annotation__8953_1175081228"/> A Girl<text:bookmark-end text:name="__RefHeading___Toc2555_4237564503"/></text:h>
   <text:p text:style-name="P66"/>
   <text:p text:style-name="P65">It wouldn’t change a damn thing.</text:p>
   <text:h text:style-name="P26" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc6583_3499536570"/><office:annotation office:name="__Annotation__3155_3499536570" loext:resolved="false">
     <dc:creator>Vladimir Herdman</dc:creator>
     <dc:date>2026-07-18T19:30:02.891482000</dc:date>
     <meta:creator-initials>VTH</meta:creator-initials>
     <text:p text:style-name="Comment">The idea here’s to have about three of these same titled poems throughout. The first one will be very “hoh poh” and enamoured, very overly detailed. The second (middle) should be a little less glossy, looking back on Oliver and a bit more dull, while the last one shoul dbe brken up and spread out like Flowers for Algernon Free Association moments.</text:p>
     <text:p text:style-name="Comment"/>
    </office:annotation>Oliver From Memory<office:annotation-end office:name="__Annotation__3155_3499536570"/><text:bookmark-end text:name="__RefHeading___Toc6583_3499536570"/></text:h>
   <text:p text:style-name="P67"/>
   <text:p text:style-name="P56"/>
   <text:h text:style-name="P26" text:outline-level="2"><text:bookmark-start text:name="__RefHeading___Toc8148_1175081228"/>Part Of Oliver From Memory<text:bookmark-end text:name="__RefHeading___Toc8148_1175081228"/></text:h>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56"/>
   <text:p text:style-name="P56"/>
