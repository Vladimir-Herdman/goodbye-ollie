     <text:p text:style-name="P20"><text:a xlink:type="simple" xlink:href="#__RefHeading___Toc1025_1230340041" office:name="I’m Not Struggling" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">I’m Not Struggling<text:tab/>14</text:a></text:p>
